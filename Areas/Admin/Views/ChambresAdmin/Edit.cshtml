@model TunisiaStay.ViewModels.ChambreFormViewModel
@{
    ViewData["Title"] = "Modifier la Chambre";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 style="font-family:var(--ff-heading);color:var(--primary);margin:0;">
        <i class="fas fa-edit me-2"></i>Modifier la Chambre
    </h5>
    <a asp-area="Admin" asp-controller="ChambresAdmin" asp-action="Index" class="btn btn-sm btn-outline-primary-custom">
        <i class="fas fa-arrow-left me-1"></i>Retour
    </a>
</div>

<div class="form-card">
    <form asp-action="Edit" asp-route-id="@Model.IdChambre" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="IdChambre" />
        <asp-validation-summary class="alert-danger-custom mb-3" asp-validation-type="All" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Model" class="form-label">Type de chambre *</label>
                <select asp-for="Model" class="form-select">
                    @foreach (var t in new[] {"Standard","Deluxe","Suite Junior","Suite","Suite Présidentielle","Bungalow Plage","Vue Mer"})
                    { <option value="@t">@t</option> }
                </select>
                <span asp-validation-for="Model" class="text-danger" style="font-size:0.78rem;"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="HotelId" class="form-label">Hôtel *</label>
                <select asp-for="HotelId" class="form-select"
                        asp-items="@(new SelectList(Model.Hotels, "Id", "Name", Model.HotelId))">
                    <option value="">Choisir un hôtel…</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="Surface" class="form-label">Surface (m²) *</label>
                <input asp-for="Surface" class="form-control" type="number" min="10" max="500" />
                <span asp-validation-for="Surface" class="text-danger" style="font-size:0.78rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="PrixParNuit" class="form-label">Prix / nuit (DT) *</label>
                <input asp-for="PrixParNuit" class="form-control" type="number" min="1" step="0.01" />
                <span asp-validation-for="PrixParNuit" class="text-danger" style="font-size:0.78rem;"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Capacite" class="form-label">Capacité</label>
                <input asp-for="Capacite" class="form-control" type="number" min="1" max="20" />
            </div>
            <div class="col-md-3">
                <label asp-for="Etage" class="form-label">Étage</label>
                <input asp-for="Etage" class="form-control" type="number" min="0" max="50" />
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-md-3">
                <div class="form-check mt-4">
                    <input asp-for="Disponible" class="form-check-input" />
                    <label asp-for="Disponible" class="form-check-label">Disponible</label>
                </div>
            </div>
            <div class="col-md-9">
                <label class="form-label">Nouvelle image (optionnel)</label>
                <input asp-for="Image" type="file" class="form-control" accept="image/*" onchange="previewImg(this)" />
                <div id="imgPreview" class="mt-2"></div>
            </div>
            <div class="col-12">
                <label class="form-label">Équipements</label>
                <div class="row g-2">
                    @for (int i = 0; i < Model.AllAmenites.Count; i++)
                    {
                        var amenite = Model.AllAmenites[i];
                        var isChecked = Model.AmeniteIds.Contains(amenite.Id);
                        <div class="col-6 col-md-3">
                            <label style="display:flex;align-items:center;gap:8px;padding:0.6rem 0.9rem;border:1.5px solid @(isChecked ? "var(--primary)" : "#e5e7eb");border-radius:8px;cursor:pointer;font-size:0.85rem;transition:all 0.2s;">
                                <input type="checkbox" name="AmeniteIds" value="@amenite.Id"
                                       @(isChecked ? "checked" : "")
                                       style="accent-color:var(--primary);"
                                       onchange="this.parentElement.style.borderColor=this.checked?'var(--primary)':'#e5e7eb'" />
                                <i class="fas @amenite.IconClass" style="color:var(--primary);width:16px;"></i>
                                @amenite.Nom
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-primary-custom px-4">
                <i class="fas fa-save me-2"></i>Enregistrer
            </button>
            <a asp-area="Admin" asp-controller="ChambresAdmin" asp-action="Index" class="btn btn-outline-primary-custom">Annuler</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
function previewImg(input) {
    const p = document.getElementById('imgPreview');
    p.innerHTML = '';
    if (input.files && input.files[0]) {
        const img = document.createElement('img');
        img.src = URL.createObjectURL(input.files[0]);
        img.style = 'max-height:160px;border-radius:8px;border:2px solid #e5e7eb;';
        p.appendChild(img);
    }
}
</script>
}
