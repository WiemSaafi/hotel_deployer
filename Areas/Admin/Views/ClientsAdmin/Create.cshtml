@model TunisiaStay.ViewModels.ClientFormViewModel
@{
    ViewData["Title"] = "Nouveau Client";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Index"
       style="color:var(--gray);font-size:1.1rem;"><i class="fas fa-arrow-left"></i></a>
    <div>
        <h5 style="font-family:var(--ff-heading);color:var(--primary);margin:0;">Nouveau Client</h5>
        <p style="font-size:0.82rem;color:var(--gray);margin:0;">Ajouter un client manuellement</p>
    </div>
</div>

<div class="form-card" style="max-width:640px;">
    <form asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert-danger-custom mb-3" style="display:none;"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Prénom <span class="text-danger">*</span></label>
                <input asp-for="Prénom" class="form-control" placeholder="Prénom" />
                <span asp-validation-for="Prénom" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                <input asp-for="Nom" class="form-control" placeholder="Nom" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" placeholder="client@email.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Téléphone</label>
                <input asp-for="Telephone" class="form-control" placeholder="XX XXX XXX" />
                <span asp-validation-for="Telephone" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">N° CIN</label>
                <input asp-for="Numéro" class="form-control" placeholder="N° carte d'identité" />
                <span asp-validation-for="Numéro" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Créer le client
            </button>
            <a asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Index" class="btn btn-outline-secondary">
                Annuler
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
