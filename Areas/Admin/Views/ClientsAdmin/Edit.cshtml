@model TunisiaStay.ViewModels.ClientFormViewModel
@{
    ViewData["Title"] = "Modifier le Client";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Index"
       style="color:var(--gray);font-size:1.1rem;"><i class="fas fa-arrow-left"></i></a>
    <div>
        <h5 style="font-family:var(--ff-heading);color:var(--primary);margin:0;">Modifier le Client</h5>
        <p style="font-size:0.82rem;color:var(--gray);margin:0;">Mise à jour des informations</p>
    </div>
</div>

<div class="form-card" style="max-width:640px;">
    <form asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="ClientKey" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert-danger-custom mb-3" style="display:none;"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Prénom <span class="text-danger">*</span></label>
                <input asp-for="Prénom" class="form-control" />
                <span asp-validation-for="Prénom" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Téléphone</label>
                <input asp-for="Telephone" class="form-control" />
                <span asp-validation-for="Telephone" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">N° CIN</label>
                <input asp-for="Numéro" class="form-control" />
                <span asp-validation-for="Numéro" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-2"></i>Enregistrer
            </button>
            <a asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Index" class="btn btn-outline-secondary">
                Annuler
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
