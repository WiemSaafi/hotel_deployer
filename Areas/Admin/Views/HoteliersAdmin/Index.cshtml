@model IEnumerable<TunisiaStay.ViewModels.HotelierListItemViewModel>
@{
    ViewData["Title"] = "Hôteliers";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-user-tie me-2"></i>Gestion des hôteliers</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Ajouter un hôtelier
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-user-tie fa-3x mb-3 text-muted"></i>
            <p class="mb-2">Aucun hôtelier pour le moment.</p>
            <a asp-action="Create" class="btn btn-primary">Créer le premier hôtelier</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nom</th>
                        <th>Email</th>
                        <th>Hôtel assigné</th>
                        <th>Créé le</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model)
                    {
                        <tr>
                            <td><strong>@h.FullName</strong></td>
                            <td>@h.Email</td>
                            <td>
                                @if (h.HotelId.HasValue)
                                {
                                    <div>
                                        <i class="fas fa-hotel me-1 text-success"></i>
                                        <strong>@h.HotelName</strong>
                                    </div>
                                    <small class="text-muted">@h.HotelCity</small>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Aucun hôtel</span>
                                }
                            </td>
                            <td>@h.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (h.IsActive)
                                {
                                    <span class="badge bg-success">Actif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactif</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@h.Id"
                                   class="btn btn-sm btn-warning" title="Modifier">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@h.Id"
                                      method="post" style="display:inline"
                                      onsubmit="return confirm('Supprimer ce compte hôtelier ? Son hôtel sera désassigné.');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-danger" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>