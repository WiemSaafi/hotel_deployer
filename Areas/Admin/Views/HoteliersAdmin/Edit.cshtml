@model TunisiaStay.ViewModels.HotelierEditViewModel
@{
    ViewData["Title"] = "Modifier hôtelier";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-edit me-2"></i>Modifier un hôtelier</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Retour
        </a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    <form asp-action="Edit" method="post" class="card p-4" style="max-width:700px;">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="FullName" class="form-label">Nom complet</label>
            <input asp-for="FullName" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input value="@Model.Email" class="form-control" disabled readonly />
            <small class="text-muted">L'email ne peut pas être modifié.</small>
        </div>

        <div class="mb-3">
            <label asp-for="HotelId" class="form-label">Hôtel assigné</label>
            <select asp-for="HotelId" asp-items="ViewBag.AvailableHotels" class="form-select">
                <option value="">-- Aucun hôtel --</option>
            </select>
            <small class="text-muted">Choisir "Aucun hôtel" désassignera l'hôtelier.</small>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i> Enregistrer
            </button>
        </div>
    </form>
</div>