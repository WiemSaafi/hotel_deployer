@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - @(ViewData["Title"] ?? "Tableau de Bord") | TunisiaStay</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="~/css/site.css" />
  @await RenderSectionAsync("Styles", required: false)
</head>
<body style="background:var(--light-gray);font-family:var(--ff-body);">

<div style="position:fixed;top:0;left:240px;right:0;height:56px;background:#fff;border-bottom:1px solid #e5e7eb;display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;z-index:99;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
  <span style="font-family:var(--ff-heading);font-size:1rem;color:var(--primary);">@(ViewData["Title"] ?? "Tableau de Bord")</span>
  <div class="d-flex align-items-center gap-3">
    <a asp-area="" asp-controller="Home" asp-action="Index" style="font-size:0.82rem;color:var(--gray);">
      <i class="fas fa-external-link-alt me-1"></i>Voir le site
    </a>
    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
      @Html.AntiForgeryToken()
      <button class="btn btn-sm" style="font-size:0.82rem;color:var(--gray);">
        <i class="fas fa-sign-out-alt me-1"></i>Deconnexion
      </button>
    </form>
  </div>
</div>

<div class="admin-sidebar">
  <div style="padding:1rem 1.5rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.1);">
    <div style="font-family:var(--ff-heading);font-size:1.3rem;color:var(--accent);">TunisiaStay</div>
    <div style="font-size:0.72rem;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.1em;">Administration</div>
  </div>

  <nav class="nav flex-column mt-3">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
      <i class="fas fa-tachometer-alt"></i>Tableau de Bord
    </a>
    <a asp-area="Admin" asp-controller="HotelsAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HotelsAdmin" ? "active" : "")">
      <i class="fas fa-hotel"></i>Hotels
    </a>
    <a asp-area="Admin" asp-controller="ChambresAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ChambresAdmin" ? "active" : "")">
      <i class="fas fa-bed"></i>Chambres
    </a>
    <a asp-area="Admin" asp-controller="ReservationsAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ReservationsAdmin" ? "active" : "")">
      <i class="fas fa-calendar-check"></i>Reservations
    </a>
    <a asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ClientsAdmin" ? "active" : "")">
      <i class="fas fa-users"></i>Clients
    </a>
    <a asp-area="Admin" asp-controller="HoteliersAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HoteliersAdmin" ? "active" : "")">
      <i class="fas fa-user-tie"></i>Hoteliers
    </a>
  </nav>
</div>

<main class="admin-content" style="padding-top:4.5rem;">
  @if (TempData["Success"] != null)
  {
    <div class="alert-success-custom d-flex align-items-center gap-2 mb-3">
      <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
  }
  @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
