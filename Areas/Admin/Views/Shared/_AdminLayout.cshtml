@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - @(ViewData["Title"] ?? "Tableau de Bord") | TunisiaStay</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="~/css/site.css" />
  <style>
    .admin-topbar {
      position:fixed;top:0;left:260px;right:0;height:64px;
      background:rgba(255,255,255,0.85);backdrop-filter:blur(20px);
      border-bottom:1px solid rgba(0,0,0,0.06);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 2rem;z-index:99;
      transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    }
    .sidebar-brand {
      padding:1.5rem 1.8rem 1.8rem;
      border-bottom:1px solid rgba(196,163,90,0.12);
    }
    .sidebar-brand-name {
      font-family:var(--ff-heading);font-size:1.5rem;color:var(--accent);
      font-weight:600;letter-spacing:0.02em;
    }
    .sidebar-brand-sub {
      font-size:0.68rem;color:rgba(255,255,255,0.4);
      text-transform:uppercase;letter-spacing:0.15em;margin-top:2px;
    }
    .admin-sidebar .nav { padding: 0.5rem 0; }
    .sidebar-section-label {
      font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;
      color:rgba(255,255,255,0.25);padding:1.2rem 1.8rem 0.4rem;font-weight:600;
    }
    .btn { border-radius: 10px; }
    .btn-sm { border-radius: 8px; }
    .btn-primary { background: linear-gradient(135deg, var(--primary), #1a3d30); border: none; }
    .btn-primary:hover { background: linear-gradient(135deg, #1a3d30, var(--primary)); transform: translateY(-1px); }
    .btn-danger { border-radius: 8px; }
    .btn-outline-primary { border-radius: 8px; border-width: 1.5px; }
    .badge { border-radius: 20px !important; }
    .page-title-area { margin-bottom: 1.5rem; }
    .page-title-area h5 { font-weight: 600; }

    /* Page entrance animation */
    .admin-content { animation: pageIn 0.4s cubic-bezier(0.4,0,0.2,1); }
    @keyframes pageIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body style="background:#f8f9fb;font-family:var(--ff-body);">

<!-- Topbar -->
<div class="admin-topbar">
  <div class="d-flex align-items-center gap-2">
    <span style="font-family:var(--ff-heading);font-size:1.1rem;color:var(--primary);font-weight:600;">
      @(ViewData["Title"] ?? "Tableau de Bord")
    </span>
  </div>
  <div class="d-flex align-items-center gap-3">
    <a asp-area="" asp-controller="Home" asp-action="Index"
       style="font-size:0.82rem;color:var(--gray);transition:color 0.3s;display:flex;align-items:center;gap:6px;"
       onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--gray)'">
      <i class="fas fa-external-link-alt"></i>Voir le site
    </a>
    <div style="width:1px;height:24px;background:#e5e7eb;"></div>
    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
      @Html.AntiForgeryToken()
      <button class="btn btn-sm" style="font-size:0.82rem;color:var(--gray);transition:color 0.3s;"
              onmouseover="this.style.color='var(--danger)'" onmouseout="this.style.color='var(--gray)'">
        <i class="fas fa-sign-out-alt me-1"></i>Déconnexion
      </button>
    </form>
  </div>
</div>

<!-- Sidebar -->
<div class="admin-sidebar">
  <div class="sidebar-brand">
    <div class="sidebar-brand-name">Tunisia<span style="color:rgba(255,255,255,0.6);font-weight:400;">Stay</span></div>
    <div class="sidebar-brand-sub">Administration</div>
  </div>

  <div class="sidebar-section-label">Menu Principal</div>
  <nav class="nav flex-column">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
      <i class="fas fa-chart-pie"></i>Tableau de Bord
    </a>
    <a asp-area="Admin" asp-controller="HotelsAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HotelsAdmin" ? "active" : "")">
      <i class="fas fa-hotel"></i>Hotels
    </a>
    <a asp-area="Admin" asp-controller="ChambresAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ChambresAdmin" ? "active" : "")">
      <i class="fas fa-bed"></i>Chambres
    </a>
    <a asp-area="Admin" asp-controller="ReservationsAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ReservationsAdmin" ? "active" : "")">
      <i class="fas fa-calendar-check"></i>Réservations
    </a>
  </nav>

  <div class="sidebar-section-label">Gestion</div>
  <nav class="nav flex-column">
    <a asp-area="Admin" asp-controller="ClientsAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ClientsAdmin" ? "active" : "")">
      <i class="fas fa-users"></i>Clients
    </a>
    <a asp-area="Admin" asp-controller="HoteliersAdmin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HoteliersAdmin" ? "active" : "")">
      <i class="fas fa-user-tie"></i>Hôteliers
    </a>
  </nav>
</div>

<main class="admin-content" style="padding-top:5rem;">
  @if (TempData["Success"] != null)
  {
    <div class="alert-success-custom d-flex align-items-center gap-2 mb-3">
      <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
  }
  @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
