@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hotelier - @(ViewData["Title"] ?? "Espace Hôtelier") | TunisiaStay</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="~/css/site.css" />
  @await RenderSectionAsync("Styles", required: false)
  <style>
    :root {
      --hotelier-primary: #0f766e;
      --hotelier-dark: #0d5a55;
      --hotelier-accent: #14b8a6;
    }
    .hotelier-sidebar {
      position: fixed; top: 0; left: 0; width: 240px; height: 100vh;
      background: var(--hotelier-primary); z-index: 100; overflow-y: auto;
      display: flex; flex-direction: column;
    }
    .hotelier-sidebar .nav-link {
      color: rgba(255,255,255,0.75); padding: 0.65rem 1.5rem;
      display: flex; align-items: center; gap: 0.7rem;
      font-size: 0.88rem; border-radius: 0; transition: all 0.15s;
    }
    .hotelier-sidebar .nav-link:hover,
    .hotelier-sidebar .nav-link.active {
      color: #fff; background: rgba(255,255,255,0.12);
    }
    .hotelier-sidebar .nav-link i { width: 18px; text-align: center; }
    .hotelier-topbar {
      position: fixed; top: 0; left: 240px; right: 0; height: 56px;
      background: #fff; border-bottom: 1px solid #e5e7eb;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 1.5rem; z-index: 99; box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .hotelier-content {
      margin-left: 240px; padding: 5rem 2rem 2rem; min-height: 100vh;
      background: #f8fafc;
    }
  </style>
</head>
<body>

<div class="hotelier-topbar">
  <span style="font-size:1rem;color:var(--hotelier-primary);font-weight:600;">
    @(ViewData["Title"] ?? "Espace Hôtelier")
  </span>
  <div class="d-flex align-items-center gap-3">
    <a asp-area="" asp-controller="Home" asp-action="Index" style="font-size:0.82rem;color:#6b7280;">
      <i class="fas fa-external-link-alt me-1"></i>Voir le site
    </a>
    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
      @Html.AntiForgeryToken()
      <button class="btn btn-sm" style="font-size:0.82rem;color:#6b7280;">
        <i class="fas fa-sign-out-alt me-1"></i>Déconnexion
      </button>
    </form>
  </div>
</div>

<div class="hotelier-sidebar">
  <div style="padding:1.2rem 1.5rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.12);">
    <div style="font-size:1.25rem;color:#fff;font-weight:700;">TunisiaStay</div>
    <div style="font-size:0.72rem;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.1em;margin-top:2px;">Espace Hôtelier</div>
  </div>
  <nav class="nav flex-column mt-2">
    <a asp-area="Hotelier" asp-controller="Dashboard" asp-action="Index"
       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
      <i class="fas fa-chart-line"></i> Tableau de bord
    </a>
    <a asp-area="Hotelier" asp-controller="MonHotel" asp-action="Edit"
       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MonHotel" ? "active" : "")">
      <i class="fas fa-hotel"></i> Mon Hôtel
    </a>
    <a asp-area="Hotelier" asp-controller="Chambres" asp-action="Index"
       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Chambres" ? "active" : "")">
      <i class="fas fa-bed"></i> Mes Chambres
    </a>
    <a asp-area="Hotelier" asp-controller="Reservations" asp-action="Index"
       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservations" ? "active" : "")">
      <i class="fas fa-calendar-check"></i> Réservations
    </a>
    <a asp-area="Hotelier" asp-controller="Offres" asp-action="Index"
       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Offres" ? "active" : "")">
      <i class="fas fa-tags"></i> Offres & Promos
    </a>
  </nav>
</div>

<main class="hotelier-content">
  @if (TempData["Success"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
      <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @if (TempData["Error"] != null)
  {
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  }
  @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
