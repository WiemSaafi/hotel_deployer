@model TunisiaStay.Models.Offre
@{
    ViewData["Title"] = "Modifier offre";
}

<div class="container py-5">
    <h1><i class="fas fa-edit me-2"></i>Modifier l'offre — @ViewBag.HotelName</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="alert alert-danger mt-3"></div>
    }

    <form asp-action="Edit" method="post" class="card p-4 mt-4" style="max-width:700px;">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="Titre" class="form-label">Titre</label>
            <input asp-for="Titre" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="Pourcentage" class="form-label">Pourcentage (%)</label>
            <input asp-for="Pourcentage" type="number" min="1" max="90" class="form-control" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="DateDebut" class="form-label">Date de début</label>
                <input asp-for="DateDebut" type="date" class="form-control" value="@Model.DateDebut.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="DateFin" class="form-label">Date de fin</label>
                <input asp-for="DateFin" type="date" class="form-control" value="@Model.DateFin.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Offre active</label>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i> Enregistrer
            </button>
        </div>
    </form>
</div>