@{
    ViewData["Title"] = "Erreur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;">
    <div>
        <i class="fas fa-exclamation-triangle" style="font-size:4rem;color:var(--danger);display:block;margin-bottom:1rem;opacity:0.5;"></i>
        <h2 style="font-family:var(--ff-heading);">Une erreur est survenue</h2>
        <p style="color:var(--gray);">Veuillez réessayer ou revenir à l'accueil.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary-custom mt-2">
            <i class="fas fa-home me-2"></i>Retour à l'accueil
        </a>
    </div>
</div>
