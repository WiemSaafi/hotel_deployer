@model TunisiaStay.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="min-height:85vh;background:linear-gradient(135deg,var(--primary) 0%,#1e4535 50%,var(--dark) 100%);display:flex;align-items:center;padding:3rem 0;position:relative;overflow:hidden;">
  <!-- Orbs -->
  <div style="position:absolute;top:-100px;right:-100px;width:400px;height:400px;background:var(--accent);border-radius:50%;filter:blur(100px);opacity:0.15;pointer-events:none;"></div>
  <div style="position:absolute;bottom:-80px;left:-80px;width:300px;height:300px;background:var(--wine);border-radius:50%;filter:blur(80px);opacity:0.12;pointer-events:none;"></div>

  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-5 col-lg-4">
        <div style="background:rgba(255,255,255,0.97);border-radius:4px;padding:2.5rem;box-shadow:0 30px 80px rgba(0,0,0,0.3);border-top:3px solid var(--accent);">

          <div class="text-center mb-4">
            <div style="font-family:var(--ff-heading);font-size:2rem;color:var(--primary);font-weight:600;">TunisiaStay</div>
            <p style="color:var(--fog);font-size:0.83rem;margin:0.3rem 0 0;letter-spacing:0.05em;">Bienvenue — Connectez-vous</p>
          </div>

          @if (!ViewData.ModelState.IsValid)
          {
            <div style="background:#fee2e2;border-left:3px solid #dc2626;color:#991b1b;padding:0.8rem 1rem;border-radius:3px;margin-bottom:1rem;font-size:0.85rem;">
              @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
              {
                <div>@error.ErrorMessage</div>
              }
            </div>
          }

          <form method="post" action="/Account/Login">
            <input name="__RequestVerificationToken" type="hidden" value="@Html.AntiForgeryToken().ToString()" />
            @Html.AntiForgeryToken()

            <div style="margin-bottom:1.2rem;">
              <label for="inp_email" style="display:block;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--fog);font-weight:600;margin-bottom:0.4rem;">
                Adresse Email
              </label>
              <input type="email"
                     id="inp_email"
                     name="Email"
                     style="width:100%;padding:0.75rem 1rem;border:1.5px solid #d1d5db;border-radius:3px;font-size:0.9rem;font-family:var(--ff-body);outline:none;transition:border-color 0.2s;"
                     placeholder="votre@email.tn"
                     onfocus="this.style.borderColor='var(--primary)'"
                     onblur="this.style.borderColor='#d1d5db'" />
            </div>

            <div style="margin-bottom:1.5rem;">
              <label for="inp_pwd" style="display:block;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--fog);font-weight:600;margin-bottom:0.4rem;">
                Mot de Passe
              </label>
              <div style="position:relative;">
                <input type="password"
                       id="inp_pwd"
                       name="Password"
                       style="width:100%;padding:0.75rem 2.8rem 0.75rem 1rem;border:1.5px solid #d1d5db;border-radius:3px;font-size:0.9rem;font-family:var(--ff-body);outline:none;transition:border-color 0.2s;"
                       placeholder="••••••••"
                       onfocus="this.style.borderColor='var(--primary)'"
                       onblur="this.style.borderColor='#d1d5db'" />
                <button type="button" onclick="togglePwd()"
                        style="position:absolute;right:0.8rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--fog);cursor:pointer;padding:0;">
                  <i class="fas fa-eye" id="eyeIcon"></i>
                </button>
              </div>
            </div>

            <div style="display:flex;align-items:center;margin-bottom:1.5rem;">
              <input type="checkbox" id="inp_remember" name="RememberMe" value="true"
                     style="width:16px;height:16px;accent-color:var(--primary);cursor:pointer;" />
              <label for="inp_remember" style="margin-left:8px;font-size:0.83rem;color:var(--fog);cursor:pointer;">
                Se souvenir de moi
              </label>
            </div>

            <button type="submit"
                    style="width:100%;padding:0.85rem;background:var(--primary);color:#fff;border:none;border-radius:3px;font-size:0.82rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:background 0.2s;"
                    onmouseover="this.style.background='var(--dark)'"
                    onmouseout="this.style.background='var(--primary)'">
              Se Connecter
            </button>
          </form>

          <div style="text-align:center;margin-top:1.5rem;font-size:0.85rem;color:var(--fog);">
            Pas encore de compte ?
            <a href="/Account/Register" style="color:var(--primary);font-weight:600;">S'inscrire</a>
          </div>

          <div style="background:var(--snow);border-radius:3px;padding:0.9rem 1rem;margin-top:1.5rem;font-size:0.78rem;color:var(--fog);">
            <strong style="color:var(--primary);">Compte démo :</strong><br>
            admin@tunisiastay.tn &nbsp;/&nbsp; Admin@123
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
function togglePwd() {
    var pwd = document.getElementById('inp_pwd');
    var icon = document.getElementById('eyeIcon');
    if (pwd.type === 'password') {
        pwd.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        pwd.type = 'password';
        icon.className = 'fas fa-eye';
    }
}
</script>
}
