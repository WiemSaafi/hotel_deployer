@* ════════ Hotels/Index ════════ *@
@model IEnumerable<TunisiaStay.Models.Hotel>
    @{
    ViewData["Title"] = "Nos Hôtels";
    Layout = "~/Views/Shared/_Layout.cshtml";
    }
    <div class="page-header">
        <div class="container">
            <h1><i class="fas fa-hotel me-2"></i>Tous nos Hôtels</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mt-1">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Accueil</a></li>
                    <li class="breadcrumb-item active">Hôtels</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- ── Barre de filtrage ── -->
    <div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:1.2rem 0;">
        <div class="container">
            <form method="get" asp-controller="Hotels" asp-action="Index">
                <div class="d-flex flex-wrap gap-3 align-items-end">

                    <div>
                        <label class="form-label">Ville</label>
                        <select name="City" class="form-select form-select-sm" style="min-width:130px;">
                            <option value="">Toutes</option>
                            <option value="Tunis" selected="@(Context.Request.Query["City"] == "Tunis")">Tunis</option>
                            <option value="Djerba" selected="@(Context.Request.Query["City"] == "Djerba")">Djerba</option>
                            <option value="Sousse" selected="@(Context.Request.Query["City"] == "Sousse")">Sousse</option>
                            <option value="Hammamet" selected="@(Context.Request.Query["City"] == "Hammamet")">Hammamet</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Prix max / nuit (DT)</label>
                        <input type="number" name="PrixMax" class="form-control form-control-sm"
                               style="min-width:130px;" placeholder="Ex: 500"
                               value="@Context.Request.Query["PrixMax"]" />
                    </div>

                    <div>
                        <label class="form-label">Étoiles min</label>
                        <select name="EtoilesMin" class="form-select form-select-sm" style="min-width:120px;">
                            <option value="">Toutes</option>
                            <option value="3 étoiles">3 étoiles+</option>
                            <option value="4 étoiles">4 étoiles+</option>
                            <option value="5 étoiles">5 étoiles</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Voyageurs</label>
                        <select name="Capacite" class="form-select form-select-sm" style="min-width:110px;">
                            <option value="">1+</option>
                            <option value="2">2+</option>
                            <option value="3">3+</option>
                            <option value="4">4+</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary-custom btn-sm">
                            <i class="fas fa-search me-1"></i>Filtrer
                        </button>
                        <a asp-controller="Hotels" asp-action="Index" class="btn btn-outline-primary-custom btn-sm">
                            <i class="fas fa-times me-1"></i>Reset
                        </a>
                    </div>

                </div>
            </form>
        </div>
    </div>

    <!-- ── Résultats ── -->
    <div class="container py-5">
        <p style="font-size:0.82rem;color:var(--fog);margin-bottom:1.5rem;">
            <i class="fas fa-list me-1"></i>@Model.Count() hôtel(s) trouvé(s)
        </p>
        <div class="row g-4">
            @foreach (var hotel in Model)
    {
            <div class="col-md-4 fade-in-up">
                <div class="hotel-card h-100">
                    <div class="card-img-wrapper">
                        @if (!string.IsNullOrEmpty(hotel.ImagePath))
            {
                        <img src="@hotel.ImagePath" alt="@hotel.Name" />
            }
            else
            {
                        <div style="height:220px;background:linear-gradient(135deg,#1a3a4a,#2d6a7f);display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-hotel" style="font-size:4rem;color:rgba(255,255,255,0.15)"></i>
                        </div>
            }
                        <div class="badge-stars">@hotel.Classification</div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@hotel.Name</h5>
                        <p class="city-tag"><i class="fas fa-map-marker-alt"></i> @hotel.City, Tunisie</p>
                        <p style="font-size:0.85rem;color:var(--gray);flex-grow:1;">
                            @(hotel.Description?.Length > 100 ? hotel.Description[..100] + "…" : hotel.Description)
                        </p>
                        <div class="d-flex gap-3 mb-3" style="font-size:0.8rem;color:var(--gray);">
                            <span><i class="fas fa-bed me-1"></i>@hotel.Chambres.Count chambre(s)</span>
                            <span><i class="fas fa-star me-1" style="color:var(--accent)"></i>@hotel.Classification</span>
                        </div>
                        @if (hotel.Chambres.Any())
            {
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="price-range">
                                À partir de @hotel.Chambres.Min(c => c.PrixParNuit).ToString("N0") DT
                                <span>/ nuit</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-controller="Hotels" asp-action="Details" asp-route-id="@hotel.Id"
                                   class="btn btn-sm btn-outline-primary-custom">Voir l'hôtel</a>
                                <a asp-controller="Chambres" asp-action="Index" asp-route-hotelId="@hotel.Id"
                                   class="btn btn-sm btn-accent-custom">Voir chambres</a>
                            </div>
                        </div>
            }
                    </div>
                </div>
            </div>
    }
        </div>
    </div>
